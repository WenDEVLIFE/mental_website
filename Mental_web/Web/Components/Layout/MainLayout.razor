@inherits LayoutComponentBase

<div class="app-container">
    <div class="sidebar">
        <div class="logo-area">SMHASS</div>
        <div class="nav-links">
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink class="nav-item" href="admin/dashboard" Match="NavLinkMatch.All">
                        <span>Admin Dashboard</span>
                    </NavLink>
                    <NavLink class="nav-item" href="students">
                        <span>Manage Students</span>
                    </NavLink>
                    <NavLink class="nav-item" href="queue">
                        <span>Appointment Queue</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Counselor">
                <Authorized>
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <span>My Appointments</span>
                    </NavLink>
                    <NavLink class="nav-item" href="schedule">
                        <span>Schedule Settings</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Student">
                <Authorized>
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <span>Dashboard</span>
                    </NavLink>
                    <NavLink class="nav-item" href="assessment">
                        <span>Assessment</span>
                    </NavLink>
                    <NavLink class="nav-item" href="appointments">
                        <span>Appointments</span>
                    </NavLink>
                    <NavLink class="nav-item" href="resources">
                        <span>Resources</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </div>
        
        <div class="nav-item" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.1); padding: 15px;">
            <a href="/logout" data-enhance-nav="false" style="color: #ff6b6b; text-decoration: none; display: flex; align-items: center; width: 100%;">
                <span class="bi bi-box-arrow-right" style="margin-right: 10px;"></span>
                Logout
            </a>
        </div>
    </div>
    
    <div class="main-content">
        <div class="header">
            <h2 style="margin: 0; font-size: 1.2rem; color: var(--text-primary);">Mental Health Appointment Support System</h2>
        </div>
        <div class="view-container">
            @Body
        </div>
    </div>
</div>
