@page "/appointments"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@inject Mental_web.Data.MentalHealthContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

<PageTitle>Appointments</PageTitle>

<h1 style="color: var(--primary); margin-bottom: 30px;">Appointments</h1>

<div class="tabs mb-4">
    <button class="tab-btn @(ActiveTab == "book" ? "active" : "")" @onclick='() => ActiveTab = "book"'>Book New</button>
    <button class="tab-btn @(ActiveTab == "history" ? "active" : "")" @onclick='() => ActiveTab = "history"'>History & Status</button>
</div>

@if (ActiveTab == "book")
{
    <div class="card p-4">
        <h3 class="mb-4">Schedule a Session</h3>
        
        <div class="mb-3">
            <label class="form-label">Select Counselor</label>
            <select class="form-select" @bind="SelectedCounselorId">
                <option value="0">-- Select a Counselor --</option>
                @foreach (var c in Counselors)
                {
                    <option value="@c.CounselorId">@c.Name (@c.Specialization)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Preferred Date</label>
            <input type="date" class="form-control" @bind="BookingDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <div class="mb-3">
            <label class="form-label">Preferred Time</label>
            <select class="form-select" @bind="BookingTime">
                <option value="09:00 AM">09:00 AM</option>
                <option value="10:00 AM">10:00 AM</option>
                <option value="11:00 AM">11:00 AM</option>
                <option value="01:00 PM">01:00 PM</option>
                <option value="02:00 PM">02:00 PM</option>
                <option value="03:00 PM">03:00 PM</option>
                <option value="04:00 PM">04:00 PM</option>
            </select>
        </div>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert alert-info">@Message</div>
        }

        <button class="btn-primary mt-3" @onclick="BookAppointment" disabled="@(SelectedCounselorId == 0)">Request Appointment</button>
    </div>
}
else
{
    <div class="card p-4">
        <h3 class="mb-4">Appointment History</h3>
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Counselor</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (UserAppointments == null || !UserAppointments.Any())
                {
                    <tr><td colspan="5" class="text-center">No appointments found.</td></tr>
                }
                else
                {
                    @foreach (var app in UserAppointments)
                    {
                        <tr>
                            <td>@app.Date.ToShortDateString()</td>
                            <td>@app.Time</td>
                            <td>@app.Counselor.Name</td>
                            <td>
                                <span class="badge @GetStatusClass(app.Status)">@app.Status</span>
                            </td>
                            <td>
                                @if (app.Status == "Pending" || app.Status == "Approved")
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => CancelAppointment(app)">Cancel</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

<style>
    .card { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .tabs { display: flex; gap: 10px; border-bottom: 2px solid #eee; }
    .tab-btn { padding: 10px 20px; border: none; background: none; font-weight: bold; cursor: pointer; color: #666; border-bottom: 3px solid transparent; margin-bottom: -2px; }
    .tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
    .btn-primary { background: var(--primary); color: white; border: none; padding: 12px 25px; border-radius: 12px; font-weight: bold; cursor: pointer; }
    .btn-primary:disabled { background: #ccc; cursor: not-allowed; }
    .badge { padding: 5px 10px; border-radius: 10px; font-size: 0.8rem; }
    .bg-pending { background: #fff3e0; color: #ef6c00; }
    .bg-approved { background: #e8f5e9; color: #2e7d32; }
    .bg-cancelled { background: #f5f5f5; color: #9e9e9e; }
    .bg-declined { background: #ffebee; color: #c62828; }
</style>

@code {
    private string ActiveTab = "book";
    private List<Mental_web.Data.Counselor> Counselors = new();
    private List<Mental_web.Data.Appointment>? UserAppointments;
    private int SelectedCounselorId;
    private DateTime BookingDate = DateTime.Today.AddDays(1);
    private string BookingTime = "10:00 AM";
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        Counselors = await DbContext.Counselors.ToListAsync();
        await LoadUserAppointments();
    }

    private async Task LoadUserAppointments()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdStr, out int userId))
        {
            UserAppointments = await DbContext.Appointments
                .Include(a => a.Counselor)
                .Where(a => a.StudentId == userId)
                .OrderByDescending(a => a.Date)
                .ToListAsync();
        }
    }

    private async Task BookAppointment()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdStr, out int userId))
        {
            // Parse "10:00 AM" into TimeSpan
            var parsedTime = DateTime.Parse(BookingTime).TimeOfDay;

            var appointment = new Mental_web.Data.Appointment
            {
                StudentId = userId,
                CounselorId = SelectedCounselorId,
                Date = BookingDate,
                Time = parsedTime,
                Status = "Pending"
            };
            DbContext.Appointments.Add(appointment);
            await DbContext.SaveChangesAsync();
            Message = "Appointment request sent successfully!";
            await LoadUserAppointments();
            ActiveTab = "history";
        }
    }

    private async Task CancelAppointment(Mental_web.Data.Appointment app)
    {
        app.Status = "Cancelled";
        DbContext.Appointments.Update(app);
        await DbContext.SaveChangesAsync();
        await LoadUserAppointments();
    }

    private string GetStatusClass(string? status) => (status ?? "").ToLower() switch
    {
        "pending" => "bg-pending",
        "approved" => "bg-approved",
        "cancelled" => "bg-cancelled",
        "declined" => "bg-declined",
        _ => ""
    };
}
