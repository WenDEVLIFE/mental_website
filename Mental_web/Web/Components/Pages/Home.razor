@page "/"

<h1 style="color: var(--primary); margin-bottom: 30px;">Hello, Mark!</h1>

<div class="stat-grid">
    <div class="card" style="text-align: center;">
        <div class="progress-circle">85%</div>
        <h3 style="margin: 0;">Mental Health Score</h3>
        <p style="color: var(--text-secondary);">Good Standing</p>
    </div>
    
    <div class="card">
        <h3 style="color: var(--primary);">Next Appointment</h3>
        <h2 style="margin: 15px 0;">Dr. Reyes</h2>
        <p style="color: var(--text-secondary);">Tomorrow, 10:00 AM</p>
        <button class="btn-primary">View Details</button>
    </div>

    <div class="card">
        <h3 style="color: var(--primary);">Resources Read</h3>
        <h2 style="margin: 15px 0;">12 Articles</h2>
        <p style="color: var(--text-secondary);">Keep it up!</p>
        <button class="btn-primary">Browse More</button>
    </div>
</div>

<h2 style="color: var(--primary); margin: 40px 0 20px;">Recommended Tips for You</h2>
<div class="stat-grid">
    <div class="card">
        <h4 style="margin: 0 0 10px; color: var(--primary);">Practice Deep Breathing</h4>
        <p style="font-size: 0.9rem;">5 mins a day reduces stress significantly. Try it before your next class.</p>
    </div>
    <div class="card">
        <h4 style="margin: 0 0 10px; color: var(--primary);">Hydration & Mood</h4>
        <p style="font-size: 0.9rem;">Drinking enough water can improve focus and emotional stability.</p>
    </div>
</div>

<style>
    .btn-primary {
        background-color: var(--primary);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
        margin-top: 10px;
    }
</style>
